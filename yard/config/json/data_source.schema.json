{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "kind"],
  "properties": {
    "name":           { "type": "string" },
    "kind":           { "type": "string", "enum": ["prod_snapshot", "synthetic", "fixtures", "external_mock"] },
    "location":       { "type": "string" },
    "refresh_policy": { "type": "string", "enum": ["on_demand", "periodic", "per_test_run", "versioned"] },
    "notes":          { "type": "string" }
  },
  "additionalProperties": true
}
