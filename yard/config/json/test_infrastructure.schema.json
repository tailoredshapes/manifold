{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "provider"],
  "properties": {
    "name":          { "type": "string" },
    "provider":      { "type": "string", "enum": ["docker", "aws_ec2", "aws_ecs", "azure_container", "gcp_gke", "kubernetes", "external_saas", "local"] },
    "region":        { "type": "string" },
    "instance_type": { "type": "string" },
    "cost_per_hour": { "type": "string" },
    "notes":         { "type": "string" }
  },
  "additionalProperties": true
}
