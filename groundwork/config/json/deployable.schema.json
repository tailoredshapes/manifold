{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "repo_url": { "type": "string" },
    "team_id": { "type": "string" },
    "deployment_status": {
      "type": ["string", "null"],
      "enum": ["operational", "degraded", "down", "unknown", null],
      "default": "unknown"
    }
  },
  "additionalProperties": true
}
